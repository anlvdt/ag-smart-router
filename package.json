{
    "name": "grav",
    "displayName": "Grav — Autopilot for Antigravity",
    "description": "Autopilot cho Antigravity AI. Auto-approve, auto-scroll, quota radar, AI learning engine.",
    "version": "1.0.3",
    "icon": "icons/icon.png",
    "publisher": "ANLE",
    "repository": {
        "type": "git",
        "url": "https://github.com/anlvdt/grav"
    },
    "engines": {
        "vscode": "^1.60.0"
    },
    "extensionKind": ["ui"],
    "categories": ["Other"],
    "activationEvents": ["onStartupFinished"],
    "main": "./src/extension.js",
    "contributes": {
        "commands": [
            { "command": "grav.inject", "title": "Grav: Inject Runtime" },
            { "command": "grav.eject", "title": "Grav: Eject Runtime" },
            { "command": "grav.dashboard", "title": "Grav: Dashboard" },
            { "command": "grav.diagnostics", "title": "Grav: Diagnostics" },
            { "command": "grav.manageTerminal", "title": "Grav: Manage Terminal Commands (Whitelist/Blacklist)" },
            { "command": "grav.learnStats", "title": "Grav: View Learning Stats" }
        ],
        "keybindings": [
            { "command": "grav.dashboard", "key": "ctrl+shift+d", "mac": "cmd+shift+d" }
        ],
        "configuration": {
            "title": "Grav",
            "properties": {
                "grav.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Bật/tắt Grav | Enable/disable Grav"
                },
                "grav.autoScroll": {
                    "type": "boolean",
                    "default": true,
                    "description": "Tự cuộn chat xuống cuối | Stick-to-bottom"
                },
                "grav.approvePatterns": {
                    "type": "array",
                    "items": { "type": "string" },
                    "default": ["Run", "Allow", "Always Allow", "Keep Waiting", "Continue", "Retry", "Accept all", "Allow in this Session", "Allow in this Workspace", "Always Allow Without Review", "Allow and Review", "Allow and Skip Reviewing Result", "Approve Tool Result", "Approve all", "Keep All Edits", "Keep & Continue", "Keep", "Proceed", "Trust", "Run Task", "Accept & Run", "Accept"],
                    "description": "Danh sách nút tự bấm | Button labels to auto-approve"
                },
                "grav.scrollPauseMs": {
                    "type": "number",
                    "default": 7000,
                    "description": "Nghỉ cuộn khi user kéo lên (ms)"
                },
                "grav.scrollIntervalMs": {
                    "type": "number",
                    "default": 500,
                    "description": "Tốc độ quét cuộn (ms)"
                },
                "grav.approveIntervalMs": {
                    "type": "number",
                    "default": 1000,
                    "description": "Tốc độ quét nút (ms)"
                },
                "grav.language": {
                    "type": "string",
                    "enum": ["vi", "en", "zh"],
                    "default": "vi",
                    "description": "Ngôn ngữ | Language"
                },
                "grav.terminalWhitelist": {
                    "type": "array",
                    "items": { "type": "string" },
                    "default": [],
                    "description": "Lệnh terminal thêm vào whitelist | Additional whitelisted terminal commands"
                },
                "grav.terminalBlacklist": {
                    "type": "array",
                    "items": { "type": "string" },
                    "default": [],
                    "description": "Lệnh terminal bị chặn | Blocked terminal commands (supports substring & /regex/)"
                },
                "grav.learnEnabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Tự học thói quen approve/reject | Adaptive learning from user behavior"
                },
                "grav.learnThreshold": {
                    "type": "number",
                    "default": 3,
                    "minimum": 1,
                    "maximum": 50,
                    "description": "Số lần approve để suggest whitelist | Approvals needed to suggest whitelisting"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "echo ok"
    }
}
