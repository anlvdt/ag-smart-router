{
    "name": "grav",
    "displayName": "Grav — Autopilot for Antigravity",
    "description": "Autopilot cho Antigravity AI. CDP-first auto-approve, auto-scroll, safety guard, AI learning engine. Just install and use.",
    "version": "3.0.1",
    "icon": "icons/icon.png",
    "publisher": "ANLE",
    "repository": {
        "type": "git",
        "url": "https://github.com/anlvdt/grav"
    },
    "engines": {
        "vscode": "^1.60.0"
    },
    "extensionKind": [
        "ui"
    ],
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./src/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "grav.inject",
                "title": "Grav: Inject Runtime"
            },
            {
                "command": "grav.eject",
                "title": "Grav: Eject Runtime"
            },
            {
                "command": "grav.dashboard",
                "title": "Grav: Dashboard"
            },
            {
                "command": "grav.diagnostics",
                "title": "Grav: Diagnostics"
            },
            {
                "command": "grav.manageTerminal",
                "title": "Grav: Manage Terminal Commands (Whitelist/Blacklist)"
            },
            {
                "command": "grav.learnStats",
                "title": "Grav: View Learning Stats"
            },
{
                "command": "grav.toggleCDP",
                "title": "Grav: Toggle CDP Mode (OOPIF Reach)"
            },
            {
                "command": "grav.pauseAccept",
                "title": "Grav: Pause Auto-Accept (Dừng tự bấm)"
            },
            {
                "command": "grav.resumeAccept",
                "title": "Grav: Resume Auto-Accept (Tiếp tục tự bấm)"
            },
            {
                "command": "grav.stopAllTerminals",
                "title": "Grav: Stop All Terminals (Ctrl+C tất cả)"
            },
            {
                "command": "grav.acceptAll",
                "title": "Grav: Force Accept All"
            }
        ],
        "keybindings": [
            {
                "command": "grav.dashboard",
                "key": "ctrl+shift+d",
                "mac": "cmd+shift+d"
            },
            {
                "command": "grav.pauseAccept",
                "key": "ctrl+shift+p",
                "mac": "cmd+shift+p",
                "when": "false"
            },
            {
                "command": "grav.stopAllTerminals",
                "key": "ctrl+shift+q",
                "mac": "cmd+shift+q"
            }
        ],
        "configuration": {
            "title": "Grav",
            "properties": {
                "grav.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Bật/tắt Grav | Enable/disable Grav"
                },
                "grav.autoScroll": {
                    "type": "boolean",
                    "default": true,
                    "description": "Tự cuộn chat xuống cuối | Stick-to-bottom"
                },
                "grav.approvePatterns": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "Accept all",
                        "Accept All",
                        "Accept",
                        "Accept & Run",
                        "Keep All Edits",
                        "Keep All",
                        "Keep & Continue",
                        "Keep",
                        "Continue",
                        "Retry",
                        "Keep Waiting",
                        "Proceed",
                        "Run Task",
                        "Run",
                        "Allow",
                        "Allow Once",
                        "Allow in this Session",
                        "Allow this conversation",
                        "Allow and Review",
                        "Approve Tool Result",
                        "Approve all"
                    ],
                    "description": "Danh sách nút tự bấm | Button labels to auto-approve"
                },
                "grav.scrollPauseMs": {
                    "type": "number",
                    "default": 7000,
                    "description": "Nghỉ cuộn khi user kéo lên (ms)"
                },
                "grav.scrollIntervalMs": {
                    "type": "number",
                    "default": 500,
                    "description": "Tốc độ quét cuộn (ms)"
                },
                "grav.approveIntervalMs": {
                    "type": "number",
                    "default": 1000,
                    "description": "Tốc độ quét nút (ms)"
                },
                "grav.language": {
                    "type": "string",
                    "enum": [
                        "vi",
                        "en",
                        "zh"
                    ],
                    "default": "vi",
                    "description": "Ngôn ngữ | Language"
                },
                "grav.terminalWhitelist": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Lệnh terminal thêm vào whitelist | Additional whitelisted terminal commands"
                },
                "grav.terminalBlacklist": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Lệnh terminal bị chặn | Blocked terminal commands (supports substring & /regex/)"
                },
                "grav.learnEnabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Tự học thói quen approve/reject | Adaptive learning from user behavior"
                },
                "grav.learnThreshold": {
                    "type": "number",
                    "default": 3,
                    "minimum": 1,
                    "maximum": 50,
                    "description": "Số lần approve để suggest whitelist | Approvals needed to suggest whitelisting"
                },
                "grav.cdpEnabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Bật CDP mode để reach OOPIF buttons (tự động cấu hình) | Enable CDP for OOPIF reach (auto-configured)"
                },
                "grav.cdpPort": {
                    "type": "number",
                    "default": 9333,
                    "description": "CDP debug port (mặc định 9333, tránh conflict với Antigravity Browser Control 9222)"
                },
                "grav.skipTerminalAccept": {
                    "type": "boolean",
                    "default": true,
                    "description": "Bỏ qua auto-accept terminal commands qua VS Code API (để Safety Guard xử lý) | Skip blind terminal accept via API, let runtime Safety Guard handle it"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "echo ok",
        "test": "node test/run-all.js"
    },
    "dependencies": {
        "ws": "^8.20.0"
    }
}
