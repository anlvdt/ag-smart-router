{
    "name": "grav",
    "displayName": "Grav — Autopilot for Antigravity",
    "description": "Autopilot cho Antigravity AI. Auto-approve, auto-scroll, quota radar, AI learning engine.",
    "version": "1.0.0",
    "publisher": "ANLE",
    "repository": {
        "type": "git",
        "url": "https://github.com/anlvdt/grav"
    },
    "engines": {
        "vscode": "^1.60.0"
    },
    "extensionKind": [
        "ui"
    ],
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./src/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "grav.inject",
                "title": "Grav: Inject Runtime"
            },
            {
                "command": "grav.eject",
                "title": "Grav: Eject Runtime"
            },
            {
                "command": "grav.dashboard",
                "title": "Grav: Dashboard"
            },
            {
                "command": "grav.diagnostics",
                "title": "Grav: Diagnostics"
            },
            {
                "command": "grav.manageTerminal",
                "title": "Grav: Manage Terminal Commands (Whitelist/Blacklist)"
            },
            {
                "command": "grav.learnStats",
                "title": "Grav: View Learning Stats"
            },
            {
                "command": "grav.viewWiki",
                "title": "Grav: View Knowledge Wiki"
            },
            {
                "command": "grav.lintWiki",
                "title": "Grav: Lint Knowledge Wiki"
            }
        ],
        "keybindings": [
            {
                "command": "grav.dashboard",
                "key": "ctrl+shift+d",
                "mac": "cmd+shift+d"
            }
        ],
        "configuration": {
            "title": "Grav",
            "properties": {
                "grav.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Bật/tắt Grav | Enable/disable Grav"
                },
                "grav.autoScroll": {
                    "type": "boolean",
                    "default": true,
                    "description": "Tự cuộn chat xuống cuối | Stick-to-bottom"
                },
                "grav.approvePatterns": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "Run",
                        "Allow",
                        "Always Allow",
                        "Keep Waiting",
                        "Continue",
                        "Retry"
                    ],
                    "description": "Danh sách nút tự bấm | Button labels to auto-approve"
                },
                "grav.scrollPauseMs": {
                    "type": "number",
                    "default": 7000,
                    "description": "Nghỉ cuộn khi user kéo lên (ms)"
                },
                "grav.scrollIntervalMs": {
                    "type": "number",
                    "default": 500,
                    "description": "Tốc độ quét cuộn (ms)"
                },
                "grav.approveIntervalMs": {
                    "type": "number",
                    "default": 1000,
                    "description": "Tốc độ quét nút (ms)"
                },
                "grav.language": {
                    "type": "string",
                    "enum": [
                        "vi",
                        "en",
                        "zh"
                    ],
                    "default": "vi",
                    "description": "Ngôn ngữ | Language"
                },
                "grav.terminalWhitelist": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Lệnh terminal thêm vào whitelist | Additional whitelisted terminal commands"
                },
                "grav.terminalBlacklist": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Lệnh terminal bị chặn | Blocked terminal commands (supports substring & /regex/)"
                },
                "grav.learnEnabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Tự học thói quen approve/reject | Adaptive learning from user behavior"
                },
                "grav.learnThreshold": {
                    "type": "number",
                    "default": 3,
                    "minimum": 1,
                    "maximum": 50,
                    "description": "Số lần approve để suggest whitelist | Approvals needed to suggest whitelisting"
                }
            }
        },
        "walkthroughs": [
            {
                "id": "grav.getStarted",
                "title": "Get Started with Grav",
                "description": "Set up Grav Autopilot and AI Learning Engine for Antigravity IDE",
                "steps": [
                    {
                        "id": "grav.step.inject",
                        "title": "Inject Runtime",
                        "description": "Inject the Grav runtime into Antigravity to enable auto-approve and scroll features.\n\n[Inject Runtime](command:grav.inject)",
                        "media": { "markdown": "media/walkthrough-inject.md" }
                    },
                    {
                        "id": "grav.step.dashboard",
                        "title": "Open Dashboard",
                        "description": "Open the Grav dashboard to configure Autopilot, view learning stats, and manage terminal commands.\n\n[Open Dashboard](command:grav.dashboard)",
                        "media": { "markdown": "media/walkthrough-dashboard.md" }
                    },
                    {
                        "id": "grav.step.terminal",
                        "title": "Manage Terminal Commands",
                        "description": "Customize which terminal commands are auto-approved or blocked.\n\n[Manage Commands](command:grav.manageTerminal)",
                        "media": { "markdown": "media/walkthrough-terminal.md" }
                    },
                    {
                        "id": "grav.step.learn",
                        "title": "AI Learning Engine",
                        "description": "Grav learns from your approve/reject patterns to automatically manage commands over time.\n\n[View Learning Stats](command:grav.learnStats)",
                        "media": { "markdown": "media/walkthrough-learn.md" }
                    }
                ]
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "echo ok",
        "test": "jest --verbose",
        "lint": "echo 'lint ok'"
    },
    "devDependencies": {
        "jest": "^30.3.0"
    }
}
